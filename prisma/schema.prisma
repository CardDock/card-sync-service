generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
}

model Card {
  id                    String       @id
  name                  String       @unique
  typeline              String[]
  type                  String
  humanReadableCardType String       @map("human_readable_card_type")
  frameType             FrameType    @map("frame_type")
  desc                  String       @db.Text
  race                  Race
  atk                   Int?
  def                   Int?
  level                 Int?
  scale                 Int?
  linkval               Int?
  linkmarkers           LinkMarker[]
  attribute             Attribute?
  rawData               Json         @db.Json
  manuallyEdited        Boolean      @default(false) @map("manually_edited")
  manuallyEditedAt      DateTime?    @map("manually_edited_at")
  artworks              Artwork[]
  translations          CardTranslation[]
  syncDiscrepancies     CardSyncDiscrepancy[]

  @@index([name])
  @@map("cards")
}

model CardTranslation {
  cardId                String  @map("card_id")
  language              String
  name                  String
  desc                  String  @db.Text
  type                  String?
  humanReadableCardType String? @map("human_readable_card_type")
  race                  String?

  card                  Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, language])
  @@map("card_translations")
}

enum DiscrepancyStatus {
  PENDING
  REVIEWED_LOCAL_WINS
  REVIEWED_API_WINS
  RESOLVED
}

model CardSyncDiscrepancy {
  id         String            @id @default(uuid())
  cardId     String            @map("card_id")
  fieldName  String            @map("field_name")
  localValue Json              @map("local_value")
  apiValue   Json              @map("api_value")
  status     DiscrepancyStatus @default(PENDING)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  card       Card              @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, fieldName])
  @@index([status])
  @@index([cardId])
  @@map("card_sync_discrepancies")
}

model CardSet {
  id   String  @id @default(uuid())
  name String  @unique
  code String?
  prints CardPrint[]

  @@map("card_sets")
}

model Artwork {
  id       String @id @default(uuid())
  cardId   String @map("card_id")
  imageUrl String @map("image_url")

  card          Card          @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardPrints    CardPrint[]

  @@unique([cardId, imageUrl])
  @@index([cardId])
  @@map("artworks")
}

model CardPrint {
  id        String @id @default(uuid())
  artworkId String @map("artwork_id")
  cardSetId String @map("card_set_id")

  setCode    String  @map("set_code")
  rarity     String
  rarityCode String? @map("rarity_code")
  setPrice   Float?  @map("set_price")

  artwork       Artwork        @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  cardSet       CardSet        @relation(fields: [cardSetId], references: [id], onDelete: Cascade)

  @@unique([artworkId, cardSetId, setCode, rarity])
  @@index([artworkId])
  @@index([cardSetId])
  @@map("card_prints")
}

enum SyncJobStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
}

model SyncJobLog {
  id               String        @id @default(uuid())
  status           SyncJobStatus @default(PENDING)
  language         String        @default("es")
  recordsProcessed Int           @default(0) @map("records_processed")
  errorMessage     String?       @map("error_message")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([language])
  @@map("sync_job_logs")
}

enum Attribute {
  DARK
  LIGHT
  EARTH
  WATER
  FIRE
  WIND
  DIVINE
}

enum LinkMarker {
  Top         @map("Top")
  Bottom      @map("Bottom")
  Left        @map("Left")
  Right       @map("Right")
  BottomLeft  @map("Bottom-Left")
  BottomRight @map("Bottom-Right")
  TopLeft     @map("Top-Left")
  TopRight    @map("Top-Right")
}

enum FrameType {
  normal
  effect
  ritual
  fusion
  synchro
  xyz
  link
  spell
  trap
  token
  skill
}

enum Race {
  Aqua
  Beast
  BeastWarrior @map("Beast-Warrior")
  Cyberse
  Dinosaur
  DivineBeast  @map("Divine-Beast")
  Dragon
  Fish
  Fairy
  Fiend
  Illusion
  Insect
  Machine
  Plant
  Psychic
  Pyro
  Reptile
  Rock
  SeaSerpent   @map("Sea Serpent")
  Spellcaster
  Thunder
  Warrior
  WingedBeast  @map("Winged Beast")
  Wyrm
  Zombie
  Normal
  Field
  Equip
  Continuous
  QuickPlay  @map("Quick-Play")
  Ritual
  Counter
}
