generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
}

model Card {
  id                    String       @id @default(uuid())
  externalId            String       @unique @map("external_id") // ID de la API primaria (ej: YGOPRODeck)
  name                  String
  typeline              String[] // Soporte nativo en PostgreSQL y CockroachDB. Si usas MySQL o SQLite, cambia el tipo a Json.
  type                  String
  humanReadableCardType String       @map("human_readable_card_type")
  frameType             FrameType    @map("frame_type")
  desc                  String       @db.Text // Permite almacenar textos largos que superan el límite de VARCHAR estándar.
  race                  Race
  atk                   Int? // Opcional: nulo para cartas Mágicas, Trampas y monstruos Link.
  def                   Int? // Opcional: nulo para cartas Mágicas, Trampas y monstruos Link.
  level                 Int? // Opcional: nulo para Mágicas, Trampas y monstruos Link.
  scale                 Int? // Opcional: nulo para cartas que no sean Pendulum.
  linkval               Int? // Opcional: nulo para cartas que no sean Link.
  linkmarkers           LinkMarker[] // Direcciones de las flechas Link (ej: ["Top", "Bottom-Left"])
  attribute             Attribute? // Opcional: nulo para Mágicas y Trampas.
  rawData               Json         @db.Json // Almacena los datos originales de la API para referencia futura.

  @@index([name])
  @@map("cards")
}

enum Attribute {
  DARK
  LIGHT
  EARTH
  WATER
  FIRE
  WIND
  DIVINE
}

enum LinkMarker {
  Top         @map("Top")
  Bottom      @map("Bottom")
  Left        @map("Left")
  Right       @map("Right")
  BottomLeft  @map("Bottom-Left")
  BottomRight @map("Bottom-Right")
  TopLeft     @map("Top-Left")
  TopRight    @map("Top-Right")
}

enum FrameType {
  normal
  effect
  ritual
  fusion
  synchro
  xyz
  link
  spell
  trap
  token
  skill
}

enum Race {
  Aqua
  Beast
  BeastWarrior @map("Beast-Warrior")
  Cyberse
  Dinosaur
  DivineBeast  @map("Divine-Beast")
  Dragon
  Fish
  Fairy
  Fiend
  Illusion
  Insect
  Machine
  Plant
  Psychic
  Pyro
  Reptile
  Rock
  SeaSerpent   @map("Sea Serpent")
  Spellcaster
  Thunder
  Warrior
  WingedBeast  @map("Winged Beast")
  Wyrm
  Zombie

  // Magias / Trampas
  Normal
  Field
  Equip
  Continuous
  QuickPlay  @map("Quick-Play")
  Ritual
  Counter
}
